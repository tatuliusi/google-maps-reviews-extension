{
  "manifest_version": 3,
  "name": "Google Maps Reviews Extractor",
  "version": "1.1.0",
  "description": "Download Google Maps business reviews within a date range as JSON.",
  "action": {
    "default_title": "Toggle Reviews Extractor Panel"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["scripting"],
  "host_permissions": ["https://www.google.com/maps/*"],
  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps/*"],
      "js": ["utils.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
